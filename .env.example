VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side scripts (seed/audit)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 3 enrichment — third-party API keys (free, instant signup)
# Census Bureau (ACS demographics, real estate housing tables):
#   https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
# U.S. Bureau of Labor Statistics (cost of living, jobs):
#   https://data.bls.gov/registrationEngine/
BLS_API_KEY=
# api.data.gov key for the FBI Crime Data API (and any other USDA/data.gov targets):
#   https://api.data.gov/signup/
FBI_DATA_GOV_KEY=
# Bureau of Economic Analysis (cost of living via Regional Price Parities):
#   https://apps.bea.gov/API/signup/
BEA_API_KEY=
# NOAA Climate Data Online (weather climate normals):
#   https://www.ncdc.noaa.gov/cdo-web/token
NOAA_CDO_TOKEN=
